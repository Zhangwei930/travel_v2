# 周密出游后端配置示例 — 复制为 .env 后按需修改

# 数据库连接。本地开发默认 SQLite（零配置即可运行）；
# 生产环境改为 PostgreSQL，例如：
# DATABASE_URL=postgresql+psycopg://zhoumi:zhoumi@127.0.0.1:5432/zhoumi
DATABASE_URL=sqlite:///./zhoumi.db

# 服务监听
HOST=0.0.0.0
PORT=8000

# 允许跨域的前端来源，逗号分隔；* 表示全部放行（仅开发环境）
CORS_ORIGINS=*

# 默认城市（MVP 单城）
DEFAULT_CITY=成都

# 地图服务商：amap / tencent / stub（stub 为本地桩实现，无需密钥）
MAP_PROVIDER=stub
AMAP_KEY=
TENCENT_MAP_KEY=

# AI 提供方：zai（z-ai/GLM 经 NVIDIA NIM）/ mimo / ollama / stub
# 云模型与 Dify 同时配置时，优先级 zai → mimo → dify → ollama → stub
AI_PROVIDER=stub

# z-ai / GLM（经 NVIDIA NIM，OpenAI 兼容接口），AI_PROVIDER=zai 时生效
ZAI_API_BASE=https://integrate.api.nvidia.com/v1
ZAI_API_KEY=
ZAI_MODEL=z-ai/glm-5.1

# MiMo（OpenAI 兼容接口），AI_PROVIDER=mimo 时生效
MIMO_API_BASE=
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro

# AI 工作流（Dify）。云模型未配置时回退到此
DIFY_API_BASE=
DIFY_API_KEY=

# 本地模型（Ollama），AI_PROVIDER=ollama 时生效
OLLAMA_BASE=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# WebSearch（SearXNG）。未配置时使用桩实现
SEARXNG_BASE=

# 知识库相似度阈值，低于此值触发 WebSearch 补充
KB_SIMILARITY_THRESHOLD=0.55

# 后台审核接口的简单令牌（请求头 X-Admin-Token）
ADMIN_TOKEN=change-me

# 天气服务密钥（和风天气等），留空使用桩实现
WEATHER_API_KEY=
